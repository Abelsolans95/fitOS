# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL for metadata, OG tags, and password reset (required for production)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Anthropic AI (required for Excel import AI detection)
ANTHROPIC_API_KEY=sk-ant-xxx

# Google Calendar OAuth (optional — enables calendar sync)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# Resend Email (optional — enables appointment email notifications)
RESEND_API_KEY=
RESEND_FROM_EMAIL=citas@your-domain.com

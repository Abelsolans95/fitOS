{
  "expo": {
    "name": "FitOS",
    "slug": "fitos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.antigravity.fitos",
      "infoPlist": {
        "NSHealthShareUsageDescription": "FitOS necesita acceso a tus datos de salud para mostrarte pasos, sueno, peso y frecuencia cardiaca.",
        "NSHealthUpdateUsageDescription": "FitOS puede guardar datos de peso y metricas corporales en Apple Salud."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": false
      }
    },
    "android": {
      "package": "com.antigravity.fitos",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "fitos"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00E5FF"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TodayWorkout",
              "label": "FitOS — Entrenamiento del día",
              "minWidth": "250dp",
              "minHeight": "180dp",
              "targetCellWidth": 4,
              "targetCellHeight": 3,
              "maxResizeWidth": "530dp",
              "maxResizeHeight": "450dp",
              "description": "Ve tu entrenamiento de hoy sin abrir la app",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ],
      "./plugins/withIOSWidget",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "FitOS necesita acceso a tus datos de salud para mostrarte pasos, sueno, peso y frecuencia cardiaca.",
          "NSHealthUpdateUsageDescription": "FitOS puede guardar datos de peso y metricas corporales en Apple Salud."
        }
      ],
      [
        "react-native-health-connect",
        {
          "requestPermissionsBackCompat": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
